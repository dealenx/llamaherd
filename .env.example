# LlamaHerd environment variables — template
# Copy this file to .env and fill in your values. .env is gitignored.

# --- libSQL database (remote, persistent across container redeployments) ---
# Point both proxy.db (client registry) and usage.db at a libSQL instance.
# Works with Turso Cloud (Bearer) or self-hosted sqld (Basic auth).
LLAMAHERD_DB=http://your-libsql-host:port
LLAMAHERD_DB_AUTH_USER=libsql
LLAMAHERD_DB_AUTH_TOKEN=your-password-or-token
# Optional: separate database for usage tracking
# LLAMAHERD_USAGE_DB=http://another-host:port

# --- Proxy settings (override config.yaml values) ---
# LLAMAHERD_ADMIN_TOKEN=change-me-to-a-secure-random-string
# LLAMAHERD_HOST=0.0.0.0
# LLAMAHERD_PORT=8399
# LLAMAHERD_CONFIG=/app/config.yaml